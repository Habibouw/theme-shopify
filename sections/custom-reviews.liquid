<style>
  .custom-reviews-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: sans-serif;
    color: #333;
  }
  .reviews-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .reviews-title-block h2 {
    margin: 0 0 5px 0;
    font-size: 1.2rem;
    font-weight: 400;
  }
  .reviews-stats {
    font-size: 0.9rem;
  }
  .reviews-stats strong {
    font-size: 1.1rem;
    margin-right: 5px;
  }
  .reviews-stats span {
    color: #777;
  }
  .reviews-actions {
    display: flex;
    gap: 10px;
  }
  .btn-write {
    background: #000;
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }
  .btn-icon {
    background: #fff;
    border: 1px solid #ccc;
    padding: 10px 12px;
    border-radius: 4px;
    cursor: pointer;
  }
  .review-item {
    border-top: 1px solid #eee;
    padding: 30px 0;
  }
  .review-stars {
    color: #000;
    font-size: 1.2rem;
    margin-bottom: 10px;
  }
  .review-author {
    font-weight: bold;
    font-size: 0.9rem;
    margin: 0;
  }
  .review-date {
    color: #999;
    font-size: 0.8rem;
    margin-bottom: 15px;
  }
  .review-title {
    font-weight: bold;
    font-size: 1.1rem;
    margin: 0 0 10px 0;
  }
  .review-text {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 15px;
  }
  .review-image img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
  }
</style>

<div class="custom-reviews-section">
  <div class="reviews-header">
    <div class="reviews-title-block">
      <h2>{{ section.settings.heading }}</h2>
      <div class="reviews-stats">
        <strong>{{ section.settings.average_rating }}</strong> 
        <span>{{ section.settings.total_reviews }} Kundenbewertungen</span>
      </div>
    </div>
    <div class="reviews-actions">
      <button class="btn-write">Eine Bewertung schreiben</button>
      <button class="btn-icon">▽</button>
      <button class="btn-icon">⇅</button>
    </div>
  </div>

  <div class="reviews-list">
    {% for block in section.blocks %}
      <div class="review-item" {{ block.shopify_attributes }}>
        <div class="review-stars">
          {% assign rating = block.settings.rating | default: 5 %}
          {% for i in (1..5) %}
            {% if i <= rating %}★{% else %}☆{% endif %}
          {% endfor %}
        </div>
        <p class="review-author">{{ block.settings.author }}</p>
        <div class="review-date">{{ block.settings.date }}</div>
        <p class="review-title">{{ block.settings.title }}</p>
        <div class="review-text">{{ block.settings.text }}</div>
        
        {% if block.settings.image != blank %}
          <div class="review-image">
            <img src="{{ block.settings.image | image_url: width: 200, height: 200, crop: 'center' }}" alt="Photo client">
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Avis Clients",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre principal",
