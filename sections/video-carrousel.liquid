<style>
  .custom-video-section {
    background-color: #E8DDD3;
    padding-bottom: 60px;
  }
  
  .marquee-wrapper {
    background-color: #000;
    color: #fff;
    padding: 12px 0;
    overflow: hidden;
    white-space: nowrap;
    display: flex;
    font-family: sans-serif;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .marquee-content {
    display: flex;
    gap: 40px;
    animation: marquee 40s linear infinite;
    padding-right: 40px;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .video-slider-container {
    max-width: 1200px;
    margin: 40px auto 0;
    padding: 0 20px;
    position: relative;
  }
  .video-track {
    display: flex;
    justify-content: center;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 20px;
  }
  .video-track::-webkit-scrollbar {
    display: none;
  }
  .video-card {
    flex: 0 0 300px;
    height: 530px;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    scroll-snap-align: center;
    background: #000;
    cursor: pointer;
  }
  
  .video-card:hover {
    transform: scale(1.02);
    transition: transform 0.3s ease;
  }

  .video-card img, .video-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }
  
  .play-icon {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 30px;
    height: 30px;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 12px;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.2s ease;
    opacity: 0;
  }

  .video-card.is-paused .play-icon {
    opacity: 1;
  }

  .video-stars {
    position: absolute;
    bottom: 20px;
    left: 0;
    width: 100%;
    text-align: center;
    color: #fff;
    font-size: 18px;
    letter-spacing: 3px;
    z-index: 2;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .video-track {
      justify-content: flex-start;
    }
    .video-card {
      flex: 0 0 260px;
      height: 460px;
    }
  }
</style>

<div class="custom-video-section">
  
  <div class="marquee-wrapper">
    <div class="marquee-content">
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
    </div>
    <div class="marquee-content" aria-hidden="true">
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
    </div>
  </div>

  <div class="video-slider-container">
    <div class="video-track">
      {% for block in section.blocks %}
        <div class="video-card" {{ block.shopify_attributes }} onclick="toggleSliderVideo(this)">
          
          <div class="play-icon">▶</div>
          
          {% if block.settings.video_url != blank %}
            <video autoplay loop muted playsinline>
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {% elsif block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="Avis vidéo">
          {% else %}
            <div style="width: 100%; height: 100%; background: #ccc;"></div>
          {% endif %}

          <div class="video-stars">★★★★★</div>
          
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  function toggleSliderVideo(element) {
    const video = element.querySelector('video');
    if (!video) return; 
    
    if (video.paused) {
      video.play();
      element.classList.remove('is-paused');
    } else {
      video.pause();
      element.classList.add('is-paused');
    }
  }
</script>

{% schema %}
{
  "name": "Carrousel Vidéos",
  "settings": [
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Texte du bandeau défilant",
      "default": "Invisible. Toujours. • Aucune marque • Zéro armature • Coton respirant • Posture redressée •"
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Vidéo/Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de couverture"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Lien de la vidéo MP4 (optionnel, remplace l'image)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carrousel Vidéos UGC",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" }
      ]
    }
  ]
}
{% endschema %}