            "liquid": "<style>\n  .ugc-header {\n    font-size: 15px;\n    font-weight: bold;\n    text-align: center;\n    color: #1a1a1a;\n    margin-bottom: 12px;\n    letter-spacing: 0.5px;\n  }\n\n  .ugc-grid-wrapper {\n    display: grid !important;\n    grid-template-columns: repeat(3, 1fr) !important;\n    gap: 8px !important;\n    margin-bottom: 12px !important;\n    width: 100% !important;\n  }\n  \n  .ugc-item {\n    position: relative;\n    width: 100% !important;\n    aspect-ratio: 9 / 16 !important;\n    border-radius: 12px;\n    overflow: hidden;\n    background-color: #EBE6DF;\n    border: 1.5px solid #EAC9B6 !important;\n  }\n  \n  .ugc-item video {\n    width: 100% !important;\n    height: 100% !important;\n    object-fit: cover !important;\n    display: block !important;\n    position: absolute;\n    top: 0;\n    left: 0;\n  }\n  \n  .play-btn {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 30px;\n    height: 30px;\n    background-color: rgba(0, 0, 0, 0.4);\n    border: 1.5px solid #fff;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    pointer-events: none;\n    z-index: 2;\n  }\n  \n  .play-btn::after {\n    content: '';\n    display: block;\n    margin-left: 2px;\n    border-top: 5px solid transparent;\n    border-bottom: 5px solid transparent;\n    border-left: 8px solid #fff;\n  }\n</style>\n\n<div class=\"ugc-header\">Von unseren Kundinnen getestet :</div>\n\n<div class=\"ugc-grid-wrapper\">\n  <div class=\"ugc-item\">\n    <video src=\"https://cdn.shopify.com/videos/c/o/v/b8565ea05def4ea4a12ac195c69962a4.mp4\" autoplay loop muted playsinline></video>\n    <div class=\"play-btn\"></div>\n  </div>\n  <div class=\"ugc-item\">\n    <video src=\"https://cdn.shopify.com/videos/c/o/v/5fceaa776ca24c60bef7d0f8cf248232.mp4\" autoplay loop muted playsinline></video>\n    <div class=\"play-btn\"></div>\n  </div>\n  <div class=\"ugc-item\">\n    <video src=\"https://cdn.shopify.com/videos/c/o/v/5a0495ffe7e748629896feb17f5183ed.mp4\" autoplay loop muted playsinline></video>\n    <div class=\"play-btn\"></div>\n  </div>\n</div>"
